<!DOCTYPE html>
<html data-theme="light" lang="de">
  <head>
    <title><%= content_for(:title) || "Erster Advent" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <%= render "layouts/head" %>

    <style>
    button:has(+ #popover-1:popover-open) .icon-down {
  display: none;
}
button:has(+ #popover-1:popover-open) .icon-up {
  display: inline-block;
}
    </style>

  </head>

  <body class="bg-base-200 group large" data-controller="scroll-nav">

    <div
      class="
        fixed top-0 left-0 w-full z-10 duration-300 ease-in-out will-change-transform
        transition-[translate,opacity] translate-y-0 opacity-100
        group-[.small.down]:-translate-y-full group-[.small.down]:opacity-0
        group-[.small.up]:translate-y-0 group-[.small.up]:opacity-100
      "
    >
      <header
        class="
          navbar bg-transparent page-container h-full items-start duration-300 ease-in-out
          transition-[height,background-color] group-[.small]:bg-primary
          group-[.small]:h-20 lg:group-[.small]:h-[140px] group-[.small]:items-center
          group-[.large]:h-32 lg:group-[.large]:h-44
        "
      >
        <!-- left / brand -->
        <div class="navbar-start h-full">
          <a href="<%= root_path %>" class="flex h-full items-center group-[.large]:pt-4">
            <%= image_tag "logo.png", alt: "Erster Advent Logo", class: "h-full w-auto mr-4" %>
            <div
              class="
                hidden sm:block font-['Korolev'] font-bold text-[19px] leading-[19px]
                lg:text-[26px] lg:leading-[26px] group-[.small]:hidden
              "
            >
              <p class="text-black">
                1. Advent<br>Untere<br>Altstadt<br>Bern
              </p>
              <p class="text-primary-content">
                Sonntag<br>30.11.2025<br>11-17 Uhr
              </p>
            </div>
            <p
              class="
                hidden group-[.small]:block font-jakarta font-bold text-primary-content text-lg
                lg:text-[28px] whitespace-nowrap
              "
            >
              Sonntag, 30.11.2025
            </p>
          </a>
        </div>
        <!-- desktop nav -->
        <div class="navbar-end gap-2 mt-3 group-[.small]:mt-0 flex">
          <%= link_to "Geschäfte entdecken", marketing_stores_path, class: "btn-navbar" %>

          <% if current_user %>

            <div
              class="relative w-min group/dropdown"
              data-controller="dropdown"
              data-action="click@window->dropdown#closeOnOutsideClick keydown.esc@window->dropdown#close"
            >
              <button
                type="button"
                data-action="dropdown#toggle"
                class="
                  btn-navbar hidden md:flex min-w-[280px] lg:min-w-[354px] cursor-pointer
                  relative z-[2] group-[.open]/dropdown:bg-black
                  group-[.open]/dropdown:border-black group-[.open]/dropdown:text-white
                "
              >
                <span class="truncate">
                  <%= current_user.business&.business_name || current_user.email %>
                </span>
                <span
                  class="
                    shrink-0 transition-transform duration-200
                    group-[.open]/dropdown:rotate-180
                  "
                >
                  <%= heroicon "arrow-down-circle", variant: :outline, options: { class: "w-7 h-7" } %>
                </span>
              </button>
              <ul
                data-dropdown-target="menu"
                class="
                  hidden absolute left-0 top-full z-[1] -mt-7 w-full min-w-[280px]
                  lg:min-w-[354px] flex-col gap-2 bg-white rounded-b-[28px] px-6 pt-12 pb-6
                  [&:not(.hidden)]:flex
                "
              >
                <% if !current_user.adminish? %>
                  <li><%= link_to "Mein Geschäft", app_mystore_path, class: "menu-item-nav" %></li>
                  <li><%= link_to "Transaktionen", app_transactions_path, class: "menu-item-nav" %></li>
                <% else %>
                  <li><%= link_to "Admin Dashboard", admin_root_path, class: "menu-item-nav" %></li>
                <% end %>

                <li>
                  <%= link_to "Ausloggen",
                  destroy_user_session_path,
                  data: {
                    turbo_method: :delete,
                  },
                  class: "menu-item-nav" %>
                </li>
              </ul>
            </div>
          <% else %>
            <%= link_to "Anmeldung für Geschäfte",
            new_user_session_path,
            class: "btn-navbar hidden md:flex" %>
          <% end %>
        </div>

      </header>
    </div>

    <main class="min-h-screen flex flex-col relative">

      <%= render "layouts/flash", { flash: flash } %>

      <%= yield %>

    </main>

    <%= render "layouts/footer" %>
  </body>
</html>
