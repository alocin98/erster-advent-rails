<!DOCTYPE html>
<html data-theme="light" lang="de">
  <head>
    <title><%= content_for(:title) || "Erster Advent Bern" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= render "layouts/head" %>
  </head>

  <body class="h-screen bg-base-200">
    <%= render "layouts/flash", { flash: flash } %>

    <div class="flex h-full flex-col">

      <div class="drawer relative flex-1 lg:drawer-open">
        <input id="my-drawer" type="checkbox" class="drawer-toggle"/>
        <div class="drawer-content h-full overflow-y-auto bg-base-200">
          <div class="mx-auto flex min-h-full w-full flex-col">

            <!-- Mobile top bar with drawer toggle -->
            <div
              class="
                sticky top-0 z-10 flex items-center gap-3 bg-primary px-4 py-3
                text-primary-content lg:hidden
              "
            >
              <label
                for="my-drawer"
                aria-label="Menü öffnen"
                class="btn btn-ghost btn-square btn-sm text-primary-content"
              >
                <%= heroicon "bars-3", variant: :outline, options: { class: "w-6 h-6" } %>
              </label>
              <%= image_tag "logo.svg", alt: "Erster Advent Logo", class: "h-7 w-auto" %>
              <span class="font-jakarta font-bold"><%= content_for(:title) || "Admin" %></span>
            </div>

            <div
              class="
                mx-auto w-full max-w-[1400px] flex-1 px-5 py-8 sm:px-8 lg:px-12 lg:py-10
              "
            >
              <%= yield %>
            </div>
          </div>
        </div>
        <div class="drawer-side z-20">
          <label for="my-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
          <aside class="h-full w-72 max-w-full bg-primary text-primary-content">
            <div class="flex h-full flex-col gap-6 px-4 py-6">
              <a href="<%= root_path %>" class="flex items-center gap-3 px-2">
                <span
                  class="
                    flex h-12 w-12 shrink-0 items-center justify-center rounded-full
                    bg-secondary text-secondary-content
                  "
                >
                  <%= image_tag "logo.svg", alt: "Erster Advent Logo", class: "h-8 w-auto" %>
                </span>
                <span>
                  <span class="block font-jakarta font-bold text-sm leading-tight">
                    1. Advent Untere Altstadt
                  </span>
                  <span class="block font-jakarta font-light text-xs opacity-70">
                    Admin Dashboard
                  </span>
                </span>
              </a>

              <ul class="flex-1 space-y-1 overflow-y-auto">
                <%= render "layouts/menu_item",
                link: admin_root_path,
                text: "Dashboard",
                icon: "squares-2x2" %>
                <%= render "layouts/menu_item",
                link: admin_stores_path,
                text: "Geschäfte",
                icon: "building-storefront" %>
                <%= render "layouts/menu_item",
                link: admin_products_path,
                text: "Produkte",
                icon: "shopping-bag" %>
                <%= render "layouts/menu_item",
                link: admin_users_path,
                text: "Benutzer",
                icon: "users" %>
                <%= render "layouts/menu_item",
                link: admin_orders_path,
                text: "Bestellungen",
                icon: "clipboard-document-list" %>
                <%= render "layouts/menu_item",
                link: admin_transaction_requests_path,
                text: "Anfragen",
                icon: "inbox-arrow-down" %>
                <%= render "layouts/menu_item",
                link: admin_transactions_path,
                text: "Transaktionen",
                icon: "banknotes" %>
                <%= render "layouts/menu_item",
                link: admin_emails_path,
                text: "E-Mails",
                icon: "envelope" %>
                <%= render "layouts/menu_item",
                link: edit_admin_cms_path,
                text: "Frontpage CMS",
                icon: "pencil-square" %>
              </ul>

              <div class="space-y-3 border-t border-white/20 pt-4">
                <div class="flex items-center gap-3 px-2">
                  <span
                    class="
                      flex h-9 w-9 shrink-0 items-center justify-center rounded-full
                      bg-white/10
                    "
                  >
                    <%= heroicon "user", variant: :outline, options: { class: "w-5 h-5" } %>
                  </span>
                  <p class="truncate font-jakarta font-light text-sm">
                    <%= current_user.business_name.presence || current_user.email %>
                  </p>
                </div>
                <%= link_to marketing_stores_path,
                class: "admin-menu-item text-sm" do %>
                  <%= heroicon "arrow-top-right-on-square",
                  variant: :outline,
                  options: {
                    class: "w-5 h-5 shrink-0",
                  } %>
                  Zur Website
                <% end %>
                <%= button_to destroy_user_session_path,
                method: :delete,
                form_class: "w-full",
                class: "admin-menu-item text-sm cursor-pointer" do %>
                  <%= heroicon "arrow-right-on-rectangle",
                  variant: :outline,
                  options: {
                    class: "w-5 h-5 shrink-0",
                  } %>
                  Logout
                <% end %>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </body>
</html>
