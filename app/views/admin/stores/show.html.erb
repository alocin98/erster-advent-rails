<%= content_for :title, @business.business_name.presence || "Store Details" %>

<%= link_to admin_stores_path,
class: "mb-4 inline-flex items-center gap-1 link-more text-sm md:text-base" do %>
  <%= heroicon "chevron-left", options: { class: "w-4 h-4" } %>
  Zurück zu allen Geschäften
<% end %>

<div class="admin-card mb-8 p-5">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <%= render "admin/stores/status_badge", status: @business.status %>
      <div>
        <p class="font-jakarta font-bold"><%= @business.business_name %></p>
        <p class="admin-subtitle"><%= @business.user&.email %></p>
      </div>
    </div>
    <%= form_with model: @business,
    url: admin_store_path(@business),
    method: :patch,
    class: "flex flex-wrap items-center gap-2",
    local: true do |f| %>
      <select name="business[status]" class="select select-bordered rounded-full w-48">
        <option value="pending" <%= "selected" if @business.pending? %>>Wartend</option>
        <option value="confirmed" <%= "selected" if @business.confirmed? %>>Bestätigt</option>
        <option value="rejected" <%= "selected" if @business.rejected? %>>Abgelehnt</option>
      </select>
      <%= f.submit "Aktualisieren", class: "btn btn-primary rounded-full" %>
    <% end %>
  </div>
</div>

<%= render "shared/business_profile", business: @business, images: @images %>
