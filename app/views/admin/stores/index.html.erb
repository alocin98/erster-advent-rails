<%= content_for :title, "Geschäfte" %>

<%= render "admin/shared/page_header",
title: "Geschäfte",
subtitle: "Alle registrierten Geschäfte verwalten und prüfen" %>

<section class="w-full space-y-6">
  <%= form_with url: admin_stores_path, method: :get do %>
    <label class="admin-search max-w-xl">
      <%= heroicon "magnifying-glass",
      options: {
        class: "w-5 h-5 shrink-0 text-black/40",
      } %>
      <%= text_field_tag :q, @q, placeholder: "Geschäft suchen...", type: :search %>
    </label>
  <% end %>

  <%= render "admin/stores/list", businesses: @businesses %>

  <div class="flex justify-center">
    <%== pagy_nav(@pagy) if defined?(@pagy) && @pagy.pages > 1 %>
  </div>
</section>
