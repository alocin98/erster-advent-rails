<%#
    Business list partial.
    Parameters:
    - businesses: Collection of business records to display. %>
<div class="admin-card">
  <% if businesses.any? %>
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Inhaber</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% businesses.each do |business| %>
            <tr class="hover:bg-base-200/50">
              <td class="font-normal"><%= business.business_name %></td>
              <td><%= business.user&.email %></td>
              <td>
                <%= render "admin/stores/status_badge", status: business.status %>
              </td>
              <td class="text-right">
                <%= link_to "Details",
                admin_store_path(business),
                class: "btn btn-sm btn-outline rounded-full" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="p-8 text-center font-jakarta font-light text-base-content/60">
      Keine Geschäfte gefunden.
    </p>
  <% end %>
</div>
