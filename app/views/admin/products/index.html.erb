<%= content_for :title, "Produkte" %>

<%= render "admin/shared/page_header",
title: "Produkte",
subtitle: "Alle Produkte der registrierten Geschäfte" %>

<section class="w-full space-y-6">
  <%= form_with url: admin_products_path, method: :get do %>
    <label class="admin-search max-w-xl">
      <%= heroicon "magnifying-glass",
      options: {
        class: "w-5 h-5 shrink-0 text-black/40",
      } %>
      <%= text_field_tag :q, @q, placeholder: "Produkt oder Geschäft suchen...", type: :search %>
    </label>
  <% end %>

  <div class="admin-card">
    <% if @products.any? %>
      <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Titel</th>
            <th>Geschäft</th>
            <th>Preis</th>
            <th>Bestellungen</th>
            <th>Erstellt</th>
          </tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr class="hover:bg-base-200/50">
              <td class="font-normal"><%= product.title %></td>
              <td><%= product.user&.business&.business_name || "-" %></td>
              <td><%= number_to_currency(product.price) %></td>
              <td><%= product.total_orders %></td>
              <td><%= l product.created_at, format: :short %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
    <% else %>
      <p class="p-8 text-center font-jakarta font-light text-base-content/60">
        Keine Produkte gefunden.
      </p>
    <% end %>
  </div>

  <div class="flex justify-center">
    <%== pagy_nav(@pagy) if defined?(@pagy) && @pagy.pages > 1 %>
  </div>
</section>
