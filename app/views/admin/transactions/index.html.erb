<%= content_for :title, "Transaktionen" %>

<%= render "admin/shared/page_header",
title: "Transaktionen",
subtitle: "Alle Zahlungen im Überblick" %>

<%= render "shared/under_construction" do %>
  <section class="w-full space-y-6">
    <div class="admin-card">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Kunde</th>
            <th>Plan</th>
            <th>Status</th>
            <th>Erstellt</th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr class="hover:bg-base-200/50">
              <td><%= payment.id %></td>
              <td><%= payment.user&.email || payment.customer_email %></td>
              <td><%= payment.plan %></td>
              <td><%= payment.is_verified.presence || "Pending" %></td>
              <td><%= l payment.created_at, format: :short %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    </div>

    <div class="flex justify-center">
      <%== pagy_nav(@pagy) if defined?(@pagy) && @pagy.pages > 1 %>
    </div>
  </section>
<% end %>
