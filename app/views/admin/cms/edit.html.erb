<%= content_for :title, "Frontpage CMS" %>

<%= render "admin/shared/page_header",
title: "Frontpage CMS",
subtitle: "Inhalte der Startseite bearbeiten" %>

<%= render "shared/under_construction" do %>
  <%= form_with data: { controller: "blocks" }, class: "w-full max-w-4xl space-y-6" do |f| %>
    <div class="admin-card p-6">
      <%= f.label :title, class: "font-jakarta font-bold text-sm" %>
      <%= f.text_field :title, class: "input input-bordered mt-2 w-full rounded-full" %>
    </div>

    <div id="blocks" data-blocks-target="list" class="space-y-4">
      <%= f.fields_for :blocks do |block_fields| %>
        <%= render "cms/edit_block", f: block_fields %>
      <% end %>
    </div>

    <div class="flex gap-2">
      <button type="button" data-action="blocks#add" class="btn btn-outline rounded-full">
        + Block hinzufügen
      </button>

      <%= f.submit "Speichern", class: "btn btn-primary rounded-full" %>
    </div>
  <% end %>
<% end %>
