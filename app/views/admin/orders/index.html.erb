<%= content_for :title, "Bestellungen" %>

<%= render "admin/shared/page_header",
title: "Bestellungen",
subtitle: "Alle Bestellungen im Überblick" %>

<%= render "shared/under_construction" do %>
  <section class="w-full space-y-6">
    <div class="admin-card">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>#</th>
            <th>Produkt</th>
            <th>Kunde</th>
            <th>Menge</th>
            <th>Größe</th>
            <th>Status</th>
            <th>Erstellt</th>
          </tr>
        </thead>
        <tbody>
          <% @orders.each do |order| %>
            <tr class="hover:bg-base-200/50">
              <td><%= order.id %></td>
              <td class="font-normal"><%= order.product&.title || "-" %></td>
              <td><%= order.customer&.email || "-" %></td>
              <td><%= order.quantity %></td>
              <td><%= order.size %></td>
              <td><%= order.accept_order %></td>
              <td><%= l order.created_at, format: :short %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    </div>

    <div class="flex justify-center">
      <%== pagy_nav(@pagy) if defined?(@pagy) && @pagy.pages > 1 %>
    </div>
  </section>
<% end %>
