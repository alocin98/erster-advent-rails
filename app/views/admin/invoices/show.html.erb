<%= content_for :title, "Rechnungen" %>

<%= render "admin/shared/page_header",
title: "Rechnungen",
subtitle: "Aktuelle Bestellungen und Rechnungsexport" %>

<%= render "shared/under_construction" do %>
  <section class="w-full space-y-6">
    <div class="admin-card p-6">
      <h2 class="font-jakarta font-bold text-lg">Aktuelle Bestellungen</h2>
      <% if @recent_orders.any? %>
        <div class="mt-4 overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>#</th>
                <th>Kunde</th>
                <th>Produkt</th>
                <th>Menge</th>
                <th>Datum</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_orders.each do |order| %>
                <tr class="hover:bg-base-200/50">
                  <td><%= order.id %></td>
                  <td><%= order.customer&.email || "-" %></td>
                  <td><%= order.product&.title || "-" %></td>
                  <td><%= order.quantity %></td>
                  <td><%= l order.created_at, format: :short %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="admin-subtitle mt-4">Keine Bestellungen vorhanden.</p>
      <% end %>
    </div>

    <div class="admin-card space-y-4 p-6">
      <h2 class="font-jakarta font-bold text-lg">Export</h2>
      <p class="admin-subtitle">
        Dieser Bereich dient als Platzhalter für den späteren PDF/CSV Export
        der Rechnungen.
      </p>
      <button class="btn rounded-full" disabled>Export starten</button>
    </div>
  </section>
<% end %>
