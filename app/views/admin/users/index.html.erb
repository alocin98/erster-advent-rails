<%= content_for :title, "Benutzer" %>

<%= render "admin/shared/page_header",
title: "Benutzer",
subtitle: "Alle registrierten Benutzerkonten verwalten" %>

<section class="w-full space-y-6">
  <%= form_with url: admin_users_path,
  method: :get,
  data: {
    controller: "search",
    turbo_frame: "users_table",
  } do %>
    <label class="admin-search max-w-xl">
      <%= heroicon "magnifying-glass",
      options: {
        class: "w-5 h-5 shrink-0 text-black/40",
      } %>
      <input
        type="search"
        name="q"
        value="<%= @q %>"
        placeholder="Benutzer suchen..."
        data-search-target="input"
      />
    </label>
  <% end %>

  <%= turbo_frame_tag "users_table" do %>
    <div class="admin-card">
      <% if @users.any? %>
        <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Geschäft</th>
              <th class="text-right">Aktionen</th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr class="hover:bg-base-200/50">
                <td class="font-normal"><%= user.name.presence || "-" %></td>
                <td><%= user.email %></td>
                <td><%= user.business&.business_name || user.business_name || "-" %></td>
                <td>
                  <div class="flex justify-end gap-2">
                    <%= link_to "Details",
                    admin_user_path(user),
                    class: "btn btn-sm btn-outline rounded-full",
                    data: {
                      turbo_frame: "_top",
                    } %>

                    <% if user.business.present? %>
                      <%= link_to "Geschäft",
                      admin_store_path(user.business),
                      class: "btn btn-sm btn-outline btn-secondary rounded-full",
                      data: {
                        turbo_frame: "_top",
                      } %>
                    <% end %>

                    <%= link_to admin_user_path(user),
                    class: "btn btn-sm btn-ghost btn-square text-error",
                    title: "Benutzer löschen",
                    data: {
                      turbo_confirm: "Soll der Benutzer wirklich gelöscht werden?",
                      turbo_method: :delete,
                    } do %>
                      <%= heroicon "trash", options: { class: "w-4 h-4" } %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        </div>
      <% else %>
        <p class="p-8 text-center font-jakarta font-light text-base-content/60">
          Keine Benutzer gefunden.
        </p>
      <% end %>
    </div>

    <div class="mt-6 flex justify-center">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% end %>
</section>
