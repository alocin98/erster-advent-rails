<% categories = Array(business.categories).compact_blank %>
<% gallery_images = Array(images).compact_blank %>

<section class="page-container flex flex-row justify-between items-baseline">
  <h1 class="heading-store mt-8 md:mt-10 lg:mt-14"><%= business.business_name %></h1>
  <div class="ml-6 flex items-center gap-4">
    <%= yield if block_given? %>
  </div>
</section>

<% if categories.present? %>
  <section class="page-container mt-5 lg:mt-8">
    <div class="flex flex-wrap gap-2 lg:gap-3">
      <% categories.each do |tag| %>
        <span class="tag-pill-lg"><%= tag %></span>
      <% end %>
    </div>
  </section>
<% end %>

<% if gallery_images.any? %>
  <% gallery_repeat_count = [(8.0 / gallery_images.size).ceil, 2].max %>
  <% repeated_gallery_images = gallery_images * gallery_repeat_count %>
  <section class="business-gallery-slider mt-8 md:mt-12 lg:mt-16 overflow-hidden" data-controller="gallery-slider">
    <div class="flex w-max flex-row will-change-transform" data-gallery-slider-target="track">
      <% repeated_gallery_images.each_with_index do |image, index| %>
        <div class="overflow-hidden bg-base-200 h-64 md:h-96 xl:h-[700px]">
          <%= image_tag image,
                        class: "h-full w-auto max-w-none object-cover",
                        alt: index < gallery_images.size ? business.business_name : "" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<% if business.address.present? %>
  <section class="page-container mt-10 md:mt-14 lg:mt-20">
    <h2 class="heading-address">
      <%= business.address %>
    </h2>
  </section>
<% end %>

<% if business.first_advent_specialities.present? %>
  <section class="page-container mt-10 md:mt-14 lg:mt-20">
    <h3 class="heading-serif"><b>Besonderes am</b>
      1. Advent</h3>
    <div class="specialities-list mt-4 lg:mt-8 lg:max-w-[1226px]">
      <%= business.first_advent_specialities %>
    </div>
  </section>
<% end %>

<section class="page-container mt-10 md:mt-14 lg:mt-20">
  <div class="text-body-lg lg:max-w-[1226px]">
    <%= business.description %>
  </div>
</section>

<section class="page-container mt-10 md:mt-14 lg:mt-16 mb-16 md:mb-24">
  <div class="font-jakarta font-bold tracking-[0.01em] text-lg lg:text-[30px] lg:leading-[44px]">
    <% if business.phone.present? %>
      <p>Tel. <%= business.phone %></p>
    <% end %>
    <% if business.email.present? %>
      <p><%= mail_to business.email, business.email, class: "hover:text-secondary" %></p>
    <% end %>
    <% if business.website.present? %>
      <p>
        <%= link_to business.website.sub(%r{\Ahttps?://}, "").sub(%r{/\z}, ""),
        business.website,
        target: "_blank",
        rel: "noopener",
        class: "hover:text-secondary" %>
      </p>
    <% end %>
  </div>
  <% social_links = {
    instagram: business.instagram,
    tiktok: business.tiktok,
    linkedin: business.linkedin,
    facebook: business.facebook,
  }.compact_blank %>
  <% if social_links.any? %>
    <div class="mt-6 lg:mt-8 flex flex-wrap items-center gap-2">
      <% social_links.each do |platform, url| %>
        <%= link_to url,
                    target: "_blank",
                    rel: "noopener",
                    class: "transition-opacity hover:opacity-70" do %>
          <span class="sr-only"><%= platform.to_s.humanize %></span>
          <%= render "shared/social_icon", platform: platform %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
